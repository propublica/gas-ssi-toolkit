{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": [
      "ES2019",
      "DOM"
    ],
    "types": [
      "google-apps-script",
      "jest"
    ],
    "rootDir": ".",
    "noUnusedLocals": false
  },
  "include": [
